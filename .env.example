# Copiá este archivo a `.env` en tu máquina (no se sube a Git).
# En Vercel: "Import .env" o pegá cada clave en Environment Variables.

# --- Postgres (Supabase → Project Settings → Database) ---
# Formato correcto (usuario y contraseña van separados por ":" después de postgres):
#   postgresql://postgres:TU_CONTRASEÑA@db.<ref>.supabase.co:5432/postgres?sslmode=require
# ERROR típico que rompe Vercel/Prisma: postgresql://postgresTU_CONTRASEÑA@...  ← falta ":" y la contraseña queda pegada al usuario.
# Para la app en Vercel: podés usar pooler (6543) en DATABASE_URL si querés.
# Si usás pooler.supabase.com, la app agrega `?pgbouncer=true` si falta (requerido por Prisma + pg).
# En cada deploy de Vercel el build ejecuta `prisma migrate deploy` y `scripts/migration-safety-net.cjs`
# (DDL idempotente por conexión directa si faltara la columna devolucionVentaOrigenId).
# Si la DB no tiene las migraciones, verás errores tipo «column … does not exist» hasta que el build
# pueda conectar y aplicarlas. Asegurate de tener DIRECT_URL o DATABASE_URL correctos en Vercel.
# Para migraciones en el build (`prisma migrate deploy`): hace falta conexión directa o sin pooler.
# Opción A — dos URLs: pool transaccional (6543) en DATABASE_URL y directa en DIRECT_URL.
# Opción B — si Vercel/Supabase te creó `POSTGRES_URL_NON_POOLING`, la CLI la usa sola (ver prisma.config.ts).
# DIRECT_URL=postgresql://postgres:...@db.<ref>.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=

# Si el build en Vercel falla con P1001 «Can't reach» a db.*.supabase.co:5432, el host directo a veces no es
# alcanzable desde la red del build. En Supabase → Database → Connection string elegí «Session pool» y copiá
# la URI (puerto 5432, host *.pooler.supabase.com). Pegala en Vercel como:
# MIGRATE_DATABASE_URL=postgresql://postgres.xxx:PASSWORD@aws-....pooler.supabase.com:5432/postgres
# Tiene prioridad sobre DIRECT_URL solo para `prisma migrate deploy` y el safety-net (ver prisma.config.ts).
# MIGRATE_DATABASE_URL=

# --- Supabase API (Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Storage para PDFs/comprobantes (creá el bucket en Supabase Storage si no existe)
# SUPABASE_STORAGE_BUCKET=comprobantes
# En producción conviene forzar Supabase si tenés las keys arriba:
# UPLOAD_STORAGE=supabase

# Vercel Cron (/api/cron/vencimientos): definí el mismo secreto aquí y en Vercel.
# Vercel envía Authorization: Bearer <CRON_SECRET> al invocar el cron.
# CRON_SECRET=

# Opcional: solo este correo puede usar el panel (login sigue siendo email + contraseña en Supabase).
# Si no lo definís, cualquier usuario de Supabase Auth con sesión válida puede entrar.
# AUTH_ALLOWED_EMAIL=tu@empresa.com

# --- Solo desarrollo local (NO pongas esto en Vercel producción) ---
# AUTH_BYPASS_LOCAL=1
# LOCAL_DEV_USER_ID=

# --- Opcional: SSL para Postgres (solo si tu proveedor lo requiere) ---
# PG_SSL_NO_VERIFY=1
# PG_SSL_CA=

# Catálogo de productos (JSON de `npm run catalogo:consolidar` con el ZIP de listas Excel).
# Mejora códigos y descripciones al extraer ítems de PDFs de compra/venta.
# CATALOGO_PRODUCTOS_JSON=data/catalogo-productos.json

# --- Opcional ---
# PDF_IMPORT_TIMEOUT_MS=55000
